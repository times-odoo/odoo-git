{
  "name": "odoogit",
  "version": "1.0.0",
  "author": "Odoo R&D Developer <developer@odoo.com>",
  "homepage": "https://github.com/odoo/git_gui_odoo",
  "description": "Git GUI purpose-built for Odoo R&D developers",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -n vite,tsc,electron \"npm run dev:renderer\" \"npm run dev:main\" \"sleep 4 && npm run dev:electron\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "dev:electron": "NODE_ENV=development electron --no-sandbox .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "dist": "npm run build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "simple-git": "^3.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "zustand": "^4.5.5",
    "highlight.js": "^11.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.odoodev.odoogit",
    "productName": "OdooGit",
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Development",
      "icon": "build/icon.png",
      "executableArgs": ["--no-sandbox"]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
